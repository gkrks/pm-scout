# ── Supabase persistence ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram notifications ────────────────────────────────────────────────────
# Create a bot via @BotFather, then get your chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
# Digest channel (new PM/APM roles)
NOTIFY_TELEGRAM_DIGEST=false
TELEGRAM_DIGEST_CHAT_ID=your-chat-id
# Health alert channel (scraper errors / timeouts / suspicious results)
# Can be the same chat ID as the digest channel
NOTIFY_TELEGRAM_HEALTH=false
TELEGRAM_HEALTH_CHAT_ID=your-chat-id

# ── Email digest ──────────────────────────────────────────────────────────────
NOTIFY_EMAIL_DIGEST=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
# Use a Gmail App Password (not your account password)
# Settings → Security → 2-Step Verification → App Passwords
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=you@gmail.com
EMAIL_TO=you@gmail.com

# ── Blackout window ───────────────────────────────────────────────────────────
# Scanner will not run between BLACKOUT_START_HOUR and BLACKOUT_END_HOUR (local time).
# Set IGNORE_BLACKOUT=true to override (e.g. npm run scan:once does this automatically).
IGNORE_BLACKOUT=false
BLACKOUT_TIMEZONE=America/Los_Angeles
BLACKOUT_START_HOUR=17
BLACKOUT_END_HOUR=5

# ── Scan controls ─────────────────────────────────────────────────────────────
# Which scraper pool to run: all | api | playwright
SCAN_POOL=all

# ── Display / logging ─────────────────────────────────────────────────────────
DISPLAY_TIMEZONE=America/Los_Angeles

# ── AI providers ─────────────────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
APOLLO_API_KEY=your-apollo-api-key

# ── JD Extraction ────────────────────────────────────────────────────────────
JD_EXTRACT_MODEL=meta-llama/llama-4-scout-17b-16e-instruct  # Groq model for structured JD extraction
JD_EXTRACT_ENABLED=true                   # global toggle

# ── Check Fit (resume tailoring UI) ─────────────────────────────────────────
FIT_BASE_URL=https://reclaim-junction-slighted.ngrok-free.dev   # public URL for email links
FIT_TOKEN_SECRET=3DEXgKixkM6EoGGcHupczXonPbE_2baHtnP21asgXvCiYeG5Y     # HMAC secret for signed URLs
FIT_PORT=3847                                          # local Express server port
BULLET_SELECTOR_URL=http://127.0.0.1:8001             # Python microservice address

# ── Python bullet selector (direct Postgres) ────────────────────────────────
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres
