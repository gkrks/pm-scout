{
  "name": "resume-matcher",
  "version": "1.0.0",
  "description": "CLI tool to match a resume against a job posting",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "match": "ts-node src/index.ts match",
    "scan": "ts-node scripts/runScan.ts",
    "scan:once": "IGNORE_BLACKOUT=true ts-node scripts/runScan.ts",
    "sync:companies": "ts-node scripts/syncCompanies.ts",
    "discover:ats": "node scripts/discoverATS.js",
    "replay:pending": "ts-node scripts/replayPendingBuffer.ts",
    "extract:one": "ts-node scripts/extractOne.ts",
    "extract:skills": "ts-node scripts/extractSkills.ts",
    "fit:serve": "ts-node src/fit/server.ts",
    "test": "jest",
    "postinstall": "PLAYWRIGHT_BROWSERS_PATH=./pw-browsers ./node_modules/.bin/playwright install chromium || true"
  },
  "bin": {
    "resume-matcher": "dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@supabase/supabase-js": "^2.105.1",
    "@types/dotenv": "^6.1.1",
    "airtable": "^0.12.2",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "groq-sdk": "^1.1.2",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.16",
    "openai": "^6.35.0",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "playwright": "^1.59.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/nodemailer": "^6.4.17",
    "@types/pdf-parse": "^1.1.4",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
