{
  "name": "resume-matcher",
  "version": "1.0.0",
  "description": "CLI tool to match a resume against a job posting",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "node dist/index.js serve",
    "dev": "ts-node src/index.ts",
    "dev:serve": "ts-node src/index.ts serve",
    "match": "ts-node src/index.ts match"
  },
  "bin": {
    "resume-matcher": "dist/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "chalk": "^4.1.2",
    "cheerio": "^1.0.0",
    "commander": "^12.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "node-fetch": "^2.7.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.11",
    "@types/pdf-parse": "^1.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
